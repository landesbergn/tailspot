<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
		PrivacyInfo.xcprivacy — App Store privacy manifest.
		Required for App Store submission (iOS 17+); strongly
		recommended for TestFlight. Declares (a) the required-reason
		APIs we use and the reason codes, and (b) the categories of
		user data we collect, what we do with it, and whether we link
		it to identity or use it for tracking.

		REVIEWED 2026-07-11 for the App Store launch (GA audit):
		  - Every declared type is now Linked = TRUE. Apple's "linked to
		    the user's identity" includes pseudonymous identifiers: all
		    collection is keyed to the server device-id (backend catches/
		    leaderboard via the per-device bearer token; PostHog events +
		    session replay + MetricKit summaries via the same id as
		    distinct_id). "Anonymous" in the marketing sense (no name/
		    email/account) is NOT "not linked" in Apple's sense.
		  - Photos/Videos declaration REMOVED: catch photos are stored
		    on-device only and never transmitted (not "collected" per
		    Apple's definition), and session replay masks them
		    (.postHogMask() on every catch-photo view; the live camera
		    view never reaches replay — see PostHogSessionReplay.swift).
		MANUAL STEP (Noah, App Store Connect): keep the privacy "nutrition
		label" in sync before the next build — this manifest and the label
		are separate surfaces; the manifest does not auto-populate the label.

		Current data flows:
		  - Backend (api.tailspot.app): device registration, handle
		    claim, catch upload (incl. observer GPS coordinates),
		    leaderboard, Hangar restore. Auth via a per-device bearer
		    token.
		  - PostHog SDK (the single analytics pipeline since 2026-06-27):
		    product events, session replay (screenshot mode, catch photos
		    masked), person-property $set. distinct_id is the anonymous,
		    Keychain-persistent server device id (pseudonymous — no
		    real-world identity, but linked in Apple's sense).
		  - MetricKit: on-device diagnostics (crash counts, hang rate,
		    peak memory) summarized into PostHog events.

		Tracking: still NSPrivacyTracking = false. "Tracking" in Apple's
		sense is linking to third-party data for ads or sharing with a
		data broker; Tailspot's analytics are first-party and the device
		id is anonymous and not shared for advertising. (Confirm with a
		privacy/legal read.)

		Required-reason APIs touched:
		  - UserDefaults (@AppStorage for onboarding, handle, toggles).
		  - FileTimestamp (FileManager.attributesOfItem in the replay
		    analyzer). Keychain is NOT a required-reason API.
	-->

	<key>NSPrivacyTracking</key>
	<false/>

	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<!-- "Access info from the same app." -->
				<string>CA92.1</string>
			</array>
		</dict>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<!-- "Inside the app or group container." -->
				<string>0A2A.1</string>
			</array>
		</dict>
	</array>

	<key>NSPrivacyCollectedDataTypes</key>
	<array>
		<!-- Precise location: matches heading + GPS to ADS-B positions;
		     catch coordinates are uploaded with the catch, keyed to the
		     device id → linked. -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypePreciseLocation</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- Anonymous device id (PostHog distinct_id + backend device id),
		     Keychain-persistent. Pseudonymous, but it IS the identifier
		     everything else is keyed to → linked in Apple's sense. -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeDeviceID</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- Product interaction: PostHog product events + session replay,
		     keyed to the device id → linked. -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeProductInteraction</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
			</array>
		</dict>
		<!-- Crash data: MetricKit crash counts → PostHog, keyed to the
		     device id → linked. -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeCrashData</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- Performance data: MetricKit hang rate, peak memory → PostHog,
		     keyed to the device id → linked. -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypePerformanceData</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- User ID: the chosen spotter handle (public on the leaderboard,
		     tied to the device — linked). Pseudonymous; no email/account. -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeUserID</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
