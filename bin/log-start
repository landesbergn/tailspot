#!/usr/bin/env bash
# Intended to start a background `log stream` against the paired iPhone,
# filtered to the Tailspot subsystem, redirected to a file so bin/log-tail
# can read it.
#
# KNOWN GAP (2026-05-13): the macOS `log` command on this machine does
# not accept --device / --device-name flags — it only streams from the
# local Mac. The plan assumed otherwise. Until we have a working
# device-side log capture (candidates: `idevicesyslog` from
# libimobiledevice via Homebrew, or `xcrun devicectl device process
# launch --console` blocking attach), this script is a graceful no-op:
# it prints a notice and exits 0 so `bin/deploy` proceeds.
#
# Tracking item: see PLAN.md §9 (deferred log-streaming follow-up).
set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$here/tools/deploy/config.sh"

mkdir -p "$TAILSPOT_LOG_DIR"

# Probe: does the host `log` binary even know about a --device flag?
# The macOS `log` shipped on most current systems streams local-only.
# Grepping --help is instant and side-effect-free.
if ! log stream --help 2>&1 | grep -q -- "--device"; then
  echo "log-start: device-side streaming not supported by this macOS \`log\`." >&2
  echo "log-start: bin/log-tail will be empty until a working capture is wired up (see PLAN.md §9)." >&2
  exit 0
fi

# Below this point: the probe succeeded, so the host's `log` supports
# device streaming. Idempotent guard.
if [ -f "$TAILSPOT_LOG_PIDFILE" ]; then
  pid="$(cat "$TAILSPOT_LOG_PIDFILE")"
  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
    echo "log-stream already running (pid $pid)"
    exit 0
  fi
  rm -f "$TAILSPOT_LOG_PIDFILE"
fi

predicate="subsystem == \"$TAILSPOT_LOG_SUBSYSTEM\""

nohup log stream \
  --device "$TAILSPOT_DEVICE_ID" \
  --predicate "$predicate" \
  --style syslog \
  >"$TAILSPOT_LOG_FILE" 2>&1 &

stream_pid=$!
echo "$stream_pid" > "$TAILSPOT_LOG_PIDFILE"

sleep 1
if ! kill -0 "$stream_pid" 2>/dev/null; then
  rm -f "$TAILSPOT_LOG_PIDFILE"
  echo "log stream failed unexpectedly; see $TAILSPOT_LOG_FILE for diagnostics" >&2
  exit 1
fi

echo "log-stream running (pid $stream_pid); output -> $TAILSPOT_LOG_FILE"
