# Deploy-loop artifacts and per-user overrides
/build/
tools/deploy/config.local.sh

# OpenSky OAuth credentials baked into the build via xcconfig
# substitution. The real secrets file lives next to the project at
# ios/Tailspot/Tailspot.secrets.xcconfig and is optionally `#include?`d
# by Tailspot.xcconfig. NEVER COMMIT the secrets file — the values
# flow into Info.plist and ship in the binary; rotating after a leak
# is the only mitigation. The committed
# Tailspot.secrets.example.xcconfig is the template; copy and fill in.
ios/Tailspot/Tailspot.secrets.xcconfig

# One-off rendered HTML artifacts of docs/ markdown files. The markdown
# is canonical and committed; HTML versions are local conveniences
# (open in a browser for nicer formatting) and shouldn't bloat the
# repo. Regenerate when needed.
docs/*.html

# Icon option PNGs produced by tools/generate-icon-options.swift. The
# script is the canonical source; the output PNGs are just review
# fodder. Re-run the script when you want to iterate; the picked
# variant is installed into Assets.xcassets/AppIcon.appiconset/.
tools/icon-options/

# Hangar glyph option PNGs produced by tools/generate-hangar-options.swift.
# Same deal — the script regenerates them, the picked glyph is wired
# into HangarGlyph.swift directly.
tools/hangar-options/
