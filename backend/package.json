{
  "name": "tailspot-api",
  "version": "0.1.0",
  "description": "Tailspot backend API — position proxy, metadata, catches, and leaderboard",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --watch --experimental-strip-types src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check src test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "ingest:doc8643": "npm run build && node dist/ingest/doc8643.js",
    "ingest:faa": "npm run build && node dist/ingest/faa.js",
    "ingest:mictronics": "npm run build && node dist/ingest/mictronics.js"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.1",
    "@sentry/node": "^10.58.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  }
}
